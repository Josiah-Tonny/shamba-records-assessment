{
  "version": 2,
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "src/server/index.js" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Credentials", "value": "true" }
      ]
    }
  ]
}
